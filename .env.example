# Required (unless LLM_MODE=mock)
ANTHROPIC_API_KEY=

# Set LLM_MODE=mock to use deterministic synthetic LLM outputs (no API cost)
LLM_MODE=

# Optional model overrides
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MODEL_PREMIUM=claude-opus-4-7
CLAUDE_MAX_TOKENS=4096

# Optional data providers (currently unused — yfinance is the default)
FMP_API_KEY=
FINNHUB_API_KEY=
POLYGON_API_KEY=
FRED_API_KEY=

# Execution-cost model (defaults to IBKR Pro tier)
EXEC_COMMISSION_PER_SHARE=0.005
EXEC_COMMISSION_MIN=1.0
EXEC_SLIPPAGE_BPS=5.0
EXEC_SPREAD_BPS=5.0
EXEC_BORROW_BPS=50.0
